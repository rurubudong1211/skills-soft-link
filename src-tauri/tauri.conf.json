{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skills 软链接",
  "version": "0.1.0",
  "identifier": "com.lx.skills-soft-link",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skills 软链接",
        "width": 1280,
        "height": 800,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "wix": {
        "template": "wix/per-user-main.wxs",
        "language": {
          "zh-CN": {
            "localePath": "wix/zh-CN.wxl"
          }
        }
      },
      "nsis": {
        "languages": ["SimpChinese"]
      }
    }
  }
}
