{
  "name": "skills-soft-link",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "npm run tauri:dev",
    "build": "npm run tauri:build && npm run package:windows",
    "dev:renderer": "vite --host 127.0.0.1",
    "build:renderer": "tsc && vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:msi": "tauri build --bundles msi && npm run package:msi",
    "tauri:build:all": "tauri build --bundles msi,nsis && npm run package:windows",
    "package:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-windows-portable.ps1",
    "package:msi": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/normalize-windows-msi.ps1",
    "package:nsis": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/normalize-windows-nsis.ps1",
    "package:windows": "npm run package:msi && npm run package:nsis && npm run package:portable",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  }
}
